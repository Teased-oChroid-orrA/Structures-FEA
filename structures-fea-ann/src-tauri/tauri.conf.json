{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Structures FEA ANN",
  "version": "0.1.0",
  "identifier": "com.structures.feaann",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Structures FEA + ANN",
        "width": 1400,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
