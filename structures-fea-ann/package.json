{
  "name": "structures-fea-ann",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && vite dev --host 127.0.0.1 --port 5173 --strictPort",
    "dev:playwright": "svelte-kit sync && vite dev --host 127.0.0.1 --port 5183 --strictPort",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "npm run check",
    "test": "node --test tests/repo-hardening.test.mjs",
    "test:repo": "node --test tests/repo-hardening.test.mjs",
    "validate": "npm run check && npm test",
    "verify:offline": "node scripts/verify-offline.mjs",
    "verify:ui-budgets": "node scripts/verify-ui-budgets.mjs",
    "verify:benchmark-lock": "node scripts/verify-benchmark-lock.mjs",
    "verify:pino-signoff-lock": "node scripts/verify-pino-signoff-lock.mjs",
    "verify:pino-regression-gates": "node scripts/verify-pino-regression-gates.mjs",
    "benchmark:diff": "node scripts/generate-benchmark-diff.mjs",
    "benchmark:profile": "bash scripts/run-benchmark-profile.sh",
    "benchmark:pino-signoff": "bash scripts/run-pino-signoff-profile.sh",
    "benchmark:pino-regression-gates": "bash scripts/run-pino-regression-gates.sh",
    "train:headless:smoke": "bash scripts/run-headless-training.sh smoke",
    "train:headless:default": "bash scripts/run-headless-training.sh default",
    "train:headless:adaptive": "bash scripts/run-headless-training.sh adaptive",
    "train:headless:default-1e9": "bash scripts/run-headless-training.sh default-1e9",
    "train:headless:default-1e9-fast": "bash scripts/run-headless-training.sh default-1e9-fast",
    "train:headless:benchmark-cantilever-fast": "bash scripts/run-headless-training.sh benchmark-cantilever-fast",
    "train:headless:default-1e9:release": "HEADLESS_RELEASE=1 bash scripts/run-headless-training.sh default-1e9",
    "train:headless:exact-ui": "bash scripts/run-headless-training.sh exact-ui",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@alpinebuster/meshlib": "^0.5.0",
    "@number-flow/svelte": "^0.4.0",
    "@tauri-apps/api": "^2.0.0",
    "@threlte/core": "^8.4.1",
    "@threlte/extras": "^9.8.1",
    "@xyflow/svelte": "^1.5.1",
    "d3": "^7.9.0",
    "three": "^0.183.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0"
  }
}
